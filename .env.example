# ── Obligatoires (production / VPS) ──
SECRET_KEY=generer-une-chaine-aleatoire-de-64-caracteres-minimum
# Supabase — préférer : export SUPABASE_DB_PASSWORD=... && source scripts/export_supabase_env.sh pooler
# Hugging Face / IPv4 (recommandé) :
# DATABASE_URL=postgresql://postgres.mkciozumxpxllsjmcsyz:MOT_DE_PASSE@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require
# Direct (IPv6 ou add-on IPv4 payant) :
# DATABASE_URL=postgresql://postgres:MOT_DE_PASSE@db.mkciozumxpxllsjmcsyz.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=
GROQ_API_KEY=gsk_xxxxxxxx
FERNET_KEY=generer-avec-python-cryptography-fernet-generate-key

# ── Session & sécurité (obligatoires VPS — activés auto si DATABASE_URL PostgreSQL) ──
OSINT_PRODUCTION=1
SESSION_COOKIE_SECURE=true
WTF_CSRF_ENABLED=true
FORCE_HTTPS=true
# Talisman force_https en prod si FORCE_HTTPS=true

# ── IA multi-fournisseur (tiers gratuits — robustesse) ──
GROQ_MODEL=llama-3.3-70b-versatile
# Fournisseurs de secours (facultatifs, tous OpenAI-compatibles) :
# GEMINI_API_KEY=            # Google AI Studio — Flash gratuit ~1500 req/j
# CEREBRAS_API_KEY=          # console.cerebras.ai — inference gratuite rapide
# OPENROUTER_API_KEY=        # openrouter.ai — modèles ':free' en dernier recours
# LLM_PROVIDER_ORDER=groq,gemini,cerebras,openrouter   # ordre de bascule
# LLM_CACHE_TTL=900          # cache réponses IA (secondes)
APP_VERSION=6.5

# ── Redis & Celery (VPS docker-compose ou Redis Cloud) ──
REDIS_URL=redis://redis:6379/0
RATELIMIT_STORAGE_URI=redis://redis:6379/1
USE_CELERY=1
USE_CELERY_BEAT=true

# ── Rétention disque (tâche beat dimanche 03:00 UTC) ──
RETENTION_UPLOAD_DAYS=30

# ── Gunicorn ──
GUNICORN_WORKERS=2
PORT=7860

# ── Compression ──
COMPRESS_ALGORITHM=br,gzip
COMPRESS_BR_LEVEL=5

# ── Monitoring erreurs ──
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── CORS (origines séparées par virgule, ou * pour dev) ──
CORS_ORIGINS=https://votredomaine.io

# ── Enrichissement scans ──
HIBP_API_KEY=
SHODAN_API_KEY=
GITHUB_TOKEN=
NUMVERIFY_KEY=
PROXY_LIST=
# Instagram (instaloader) — utilise PROXY_LIST (rotation random.choice par scan Celery)
# IG_PROXY_URL=   # optionnel, ajouté au pool si défini
IG_DUMMY_USER=
IG_DUMMY_PASS=
# Session instaloader (évite login/password dans Docker — voir scripts/create_ig_session.py)
# Local : IG_SESSION_FILE=./session-ig
# Docker/VPS : IG_SESSION_FILE=/code/session-ig
IG_SESSION_FILE=

# ── Hugging Face Space (secrets HF) ──
# USE_CELERY=0
# OSINT_IG_MODE=auto          # auto = HTTP léger sur HF ; full = instaloader (VPS/RAM++)
# GUNICORN_TIMEOUT=300

# ── Scraping secours ──
SCRAPE_FALLBACK_ENABLED=true
CLOUDSCRAPER_ENABLED=true

# ── SSL sortant ──
SSL_VERIFY=true

# ── Sauvegardes (Celery beat daily ou scripts/backup.sh) ──
BACKUP_DIR=/code/backups
BACKUP_KEEP_DAYS=7

# ── Déploiement CI (secrets GitHub, pas dans .env du repo) ──
# VPS_HOST=1.2.3.4
# VPS_USER=deploy
# VPS_SSH_KEY=...
# VPS_APP_DIR=/opt/osint-ultimate
# REGISTRY_IMAGE=ghcr.io/votre-org/osint-ultimate
